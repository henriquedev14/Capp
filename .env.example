# Copie este arquivo para ".env" e ajuste os valores conforme necessário.
# NUNCA versione o arquivo ".env" real (ele já está no .gitignore).

# Conexão com o PostgreSQL.
# A porta 5433 (e não 5432) é usada de propósito: evita conflito com um
# PostgreSQL que já possa estar instalado/rodando localmente na máquina.
# Esse valor corresponde à porta exposta pelo serviço "db" no
# docker-compose.yml — funciona sem alteração ao rodar via Docker.
DATABASE_URL="postgresql://erp:erp_dev_password@localhost:5433/erp_engenharia?schema=public"

# Autenticação (NextAuth v4).
# NEXTAUTH_SECRET é obrigatório em produção — usado para assinar/criptografar
# o JWT de sessão. Gere um valor aleatório forte com:
#   openssl rand -base64 32
# NUNCA reutilize o valor de exemplo abaixo em um ambiente real.
NEXTAUTH_SECRET="troque-este-valor-por-um-segredo-aleatorio-forte"

# URL canônica da aplicação — usada pelo NextAuth para montar callbacks e
# redirecionamentos corretamente. Ajuste se a aplicação rodar em outra
# porta/host (ex: detrás de um proxy reverso em produção).
NEXTAUTH_URL="http://localhost:3000"

# Opcional: credenciais do usuário administrador criado pelo script de seed
# (npm run db:seed). Se não definidas, usa os valores padrão de
# desenvolvimento (admin@hgigroup.com.br / TrocarSenha123!) — troque a
# senha logo após o primeiro login.
SEED_ADMIN_EMAIL="admin@hgigroup.com.br"
SEED_ADMIN_PASSWORD="TrocarSenha123!"
