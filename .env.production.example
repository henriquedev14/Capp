# Copie este arquivo pra ".env" no servidor de produção e preencha os valores.
# NUNCA commite o ".env" real no git — só este ".env.production.example".

# --- Banco de dados -----------------------------------------------------
# Gere uma senha forte, por exemplo com: openssl rand -base64 24
POSTGRES_PASSWORD=troque-por-uma-senha-forte-aqui

# --- Autenticação --------------------------------------------------------
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=troque-por-um-segredo-forte-aqui

# URL pública real do sistema (com https://, sem barra no final)
NEXTAUTH_URL=https://seu-dominio.com.br

# --- E-mail transacional (Resend) ----------------------------------------
# Crie uma conta em https://resend.com, valide seu domínio lá (adiciona
# 3 registros DNS — o próprio Resend te mostra quais), pega a API key.
RESEND_API_KEY=re_troque_por_sua_chave_aqui
EMAIL_FROM="ConstruApp <sistema@seu-dominio.com.br>"

# --- Seed inicial (só usado no primeiro setup, via serviço "migrate") ----
SEED_ADMIN_EMAIL=admin@hgigroup.com.br
SEED_ADMIN_PASSWORD=troque-essa-senha-no-primeiro-login
